# Copy this file to ~/.openclaw/.env on the Pi and fill in real values.
# chmod 600 ~/.openclaw/.env
#
# Every variable listed here is referenced from openclaw.json via a SecretRef
# of shape: { source: "env", provider: "default", id: "<NAME>" }.
# Values are read at gateway startup and cached in-memory. Rotate with:
#   edit ~/.openclaw/.env  &&  openclaw secrets reload

# --- Models & web search ------------------------------------------------------
GOOGLE_API_KEY=

# --- Slack (Socket Mode) ------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- Skills -------------------------------------------------------------------
NOTION_API_KEY=
OPENAI_API_KEY=

# --- GitHub (gh CLI, used by the `github` skill) ------------------------------
# Personal Access Token (classic) with `repo` scope, or a fine-grained token
# with "Contents: Read and write" + "Pull requests: Read and write" on the
# target repos.
# `gh` reads GH_TOKEN first, then GITHUB_TOKEN. We use GITHUB_TOKEN to match
# the canonical GitHub name (same variable GitHub Actions exposes).
# Alternative: run `gh auth login` once interactively on the Pi and leave this unset.
GITHUB_TOKEN=

# --- Optional: override gateway auth token (otherwise generated per machine) --
# OPENCLAW_GATEWAY_TOKEN=
